# Copy to .env and fill in.
# The Python service reads these via python-dotenv on startup.

# PocketBase base URL (no trailing slash). For prod, use your deployed URL.
POCKETBASE_URL=http://127.0.0.1:8090

# Optional LLM providers for /llm/prompt-to-palette.
# Set either; "auto" prefers OpenAI when both present.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# APIFY_API_TOKEN=apify_api_...
# APIFY_COLOR_ACTOR=lukaskrivka/color-palette-generator
